{
  "groups": {
    "SuperAdmin": {
      "description": "超级管理员",
      "permissions": [
        "*"
      ]
    },
    "Admin": {
      "description": "管理员",
      "permissions": [
        "system.config.*",
        "user.manage.*",
        "tool.*",
        "agent.*",
        "api.*"
      ]
    },
    "Developer": {
      "description": "开发者",
      "permissions": [
        "tool.code_generator",
        "tool.file_access",
        "api.github.push",
        "agent.task.execute"
      ]
    },
    "User": {
      "description": "普通用户",
      "permissions": [
        "tool.web_search",
        "tool.data_analyze",
        "tool.chart_generate",
        "api.read",
        "api.access",
        "agent.task.create"
      ]
    },
    "Guest": {
      "description": "访客",
      "permissions": [
        "tool.web_search",
        "api.read"
      ]
    }
  }
}