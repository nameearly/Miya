{
    "type": "function",
    "function": {
        "name": "python_interpreter",
        "description": "执行Python代码。当用户说'运行代码'、'执行Python'、'计算'、'数据分析'时使用此工具。",
        "parameters": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "description": "要执行的Python代码"
                },
                "timeout": {
                    "type": "integer",
                    "description": "超时时间（秒），默认30秒",
                    "default": 30
                }
            },
            "required": ["code"]
        }
    }
}