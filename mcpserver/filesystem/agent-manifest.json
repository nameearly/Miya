{
  "name": "filesystem",
  "displayName": "文件系统服务",
  "description": "提供文件读取、写入、删除、搜索能力",
  "agentType": "mcp",
  "entryPoint": {
    "module": "mcpserver.filesystem.service",
    "class": "FilesystemService"
  },
  "capabilities": {
    "tools": [
      {
        "name": "read_file",
        "description": "读取文件内容",
        "parameters": {
          "file_path": "string",
          "offset": "number",
          "limit": "number"
        }
      },
      {
        "name": "write_file",
        "description": "写入文件",
        "parameters": {
          "file_path": "string",
          "content": "string"
        }
      },
      {
        "name": "delete_file",
        "description": "删除文件",
        "parameters": {
          "file_path": "string",
          "recursive": "boolean"
        }
      },
      {
        "name": "list_files",
        "description": "列出目录文件",
        "parameters": {
          "path": "string",
          "pattern": "string",
          "recursive": "boolean"
        }
      },
      {
        "name": "search_files",
        "description": "搜索文件内容",
        "parameters": {
          "pattern": "string",
          "path": "string",
          "include": "string"
        }
      }
    ]
  },
  "version": "1.0.0",
  "enabled": true
}