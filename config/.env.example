# ========================================
# 弥娅 MIYA - 配置示例文件
# ========================================
# 复制此文件为 .env 并修改实际值
# 注意：不要将此文件提交到公开仓库！

# ========================================
# 应用基础配置
# ========================================
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/miya.log

# ========================================
# AI大模型配置
# ========================================
# 推荐优先使用硅基流动（免费额度充足）

# 通用AI参数
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
AI_REQUEST_MAX_RETRIES=2
AI_REQUEST_TIMEOUT=30
AI_PROVIDER=siliconflow

# --- 硅基流动（推荐，首选） ---
SILICONFLOW_API_KEY=sk-你的硅基流动API密钥
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_QWEN_7B_MODEL=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_QWEN_72B_MODEL=Qwen/Qwen2.5-72B-Instruct
SILICONFLOW_DEEPSEEK_V3_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_DEEPSEEK_R1_DISTILL_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
SILICONFLOW_GLM_4_MODEL=THUDM/glm-4-9b-chat

# --- DeepSeek 官方 ---
DEEPSEEK_API_KEY=sk-你的DeepSeek API密钥
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_V3_MODEL=deepseek-chat
DEEPSEEK_R1_MODEL=deepseek-reasoner

# --- 智谱AI ---
ZHIPU_API_KEY=你的智谱API密钥
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_GLM_4_MODEL=glm-4
ZHIPU_GLM_4_PLUS_MODEL=glm-4-plus
ZHIPU_GLM_4V_MODEL=glm-4v
ZHIPU_GLM_46V_FLASH_MODEL=glm-4.6v-flash

# --- 阿里云通义千问 ---
DASHSCOPE_API_KEY=你的阿里云API密钥
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_QWEN_VL_MODEL=qwen-vl-plus

# --- Tavily AI 搜索（专为 AI 设计的搜索引擎） ---
# 注册地址: https://tavily.com/
TAVILY_API_KEY=tvly-你的Tavily API密钥

# ========================================
# QQ机器人配置
# ========================================
QQ_ONEBOT_WS_URL=ws://localhost:3001
QQ_ONEBOT_TOKEN=
QQ_BOT_QQ=你的机器人QQ号
QQ_SUPERADMIN_QQ=管理员QQ号
QQ_RECONNECT_INTERVAL=5.0
QQ_PING_INTERVAL=20
QQ_MAX_MESSAGE_SIZE=104857600
QQ_OCR_ENABLED=true
QQ_ACTIVE_CHAT_ENABLED=true

# ========================================
# Redis配置
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10

# ========================================
# Milvus配置
# ========================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=miya_memory
MILVUS_DIMENSION=1536
MILVUS_USE_LITE=false

# ========================================
# Neo4j配置
# ========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=你的Neo4j密码
NEO4J_DATABASE=neo4j

# ========================================
# 人格配置
# ========================================
PERSONALITY_WARMTH=0.5
PERSONALITY_LOGIC=0.7
PERSONALITY_CREATIVITY=0.8
PERSONALITY_EMPATHY=0.6
PERSONALITY_RESILIENCE=0.7

# ========================================
# 情绪配置
# ========================================
EMOTION_DECAY_RATE=0.1

# ========================================
# 记忆配置
# ========================================
MEMORY_TIDE_TTL=3600
MEMORY_SHORT_TERM_CAPACITY=20

# ========================================
# Runtime API配置
# ========================================
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
WEB_API_CORS_ORIGINS=*

# ========================================
# 性能配置
# ========================================
MIYA_FORCE_CPU=true

# ========================================
# 安全配置
# ========================================
INJECTION_DETECTION_ENABLED=true

# ========================================
# LifeBook配置
# ========================================
LIFEBOOK_ENABLED=true
LIFEBOOK_BASE_DIR=data/lifebook
LIFEBOOK_DEFAULT_MONTHS_BACK=1

# ========================================
# 对话上下文配置
# ========================================
CONVERSATION_CONTEXT_MAX_COUNT=5
CONVERSATION_CONTEXT_MAX_TOKENS=1000

# ========================================
# GitHub配置
# ========================================
GITHUB_REPO_OWNER=你的GitHub用户名
GITHUB_REPO_NAME=你的仓库名
GITHUB_TOKEN=ghp_你的GitHub Token
GITHUB_BRANCH=main

# ========================================
# PaddleOCR配置
# ========================================
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
