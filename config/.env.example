# ========================================
# 弥娅 MIYA - 完整配置文件
# ========================================
# 说明：
# 1. 复制此文件为 .env 并根据实际情况修改
# 2. 所有配置项都有注释说明
# 3. 部分配置项为可选，可根据需要启用
# ========================================

# ========================================
# 应用配置
# ========================================
# 调试模式：true/false
DEBUG=false

# 日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO

# 日志文件路径（可选）
LOG_FILE_PATH=logs/miya.log

# 日志文件最大大小（MB）
LOG_MAX_SIZE=100

# 日志文件备份数量
LOG_BACKUP_COUNT=10

# ========================================
# AI大模型配置（通用OpenAI兼容格式）
# ========================================
# 说明：支持所有提供OpenAI兼容API的平台
# - DeepSeek: https://api.deepseek.com/v1
# - OpenAI: https://api.openai.com/v1
# - Azure OpenAI: https://your-resource.openai.azure.com
# - 智谱AI: https://open.bigmodel.cn/api/paas/v4
# - 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# - 百度文心: https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
# - Moonshot: https://api.moonshot.cn/v1
# - 硅基流动: https://api.siliconflow.cn/v1
# - Groq: https://api.groq.com/openai/v1
# - 本地Ollama: http://localhost:11434/v1
# - 其他自定义API...

# 【主模型配置】
# API基础URL（必填）
AI_API_BASE_URL=https://api.deepseek.com/v1

# API密钥（必填）- 替换为你的实际API Key
AI_API_KEY=sk-your-api-key-here

# 模型名称（必填）
AI_MODEL=deepseek-chat

# AI生成参数（可选）
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# ========================================
# 【多模型配置】硅基流动 SiliconFlow
# ========================================
# 注册地址：https://cloud.siliconflow.cn/i/pEXepR3y
# 免费额度：新用户赠送2000万Tokens
# 支持模型：DeepSeek-V3、DeepSeek-R1、Qwen2.5、GLM-4、InternLM等

# 硅基流动 API Key（替换为你的实际API Key）
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# 硅基流动 API Base URL
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# DeepSeek V3（硅基流动）
SILICONFLOW_DEEPSEEK_V3_MODEL=deepseek-ai/DeepSeek-V3

# DeepSeek R1 Distill 7B（硅基流动）
SILICONFLOW_DEEPSEEK_R1_DISTILL_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B

# Qwen 2.5 7B Instruct（免费模型）
SILICONFLOW_QWEN_7B_MODEL=Qwen/Qwen2.5-7B-Instruct

# Qwen 2.5 72B Instruct（高性能模型）
SILICONFLOW_QWEN_72B_MODEL=Qwen/Qwen2.5-72B-Instruct

# GLM-4 9B Chat（清华智谱）
SILICONFLOW_GLM_4_MODEL=THUDM/glm-4-9b-chat

# InternLM 2.5 7B Chat（书生浦语）
SILICONFLOW_INTERNLM_MODEL=internlm/internlm2_5-7b-chat

# Llama 3.1 8B Instruct（Meta免费模型）
SILICONFLOW_LLAMA_8B_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Gemma 2 9B IT（Google）
SILICONFLOW_GEMMA_9B_MODEL=google/gemma-2-9b-it

# ========================================
# 【多模型配置】DeepSeek 官方
# ========================================
# 注册地址：https://platform.deepseek.com/
# 官方文档：https://platform.deepseek.com/api-docs/

# DeepSeek V3（通用模型）
DEEPSEEK_V3_MODEL=deepseek-chat

# DeepSeek R1（推理模型）
DEEPSEEK_R1_MODEL=deepseek-reasoner

# DeepSeek Coder V2（代码模型，已合并到V2.5）
DEEPSEEK_CODER_MODEL=deepseek-coder

# ========================================
# QQ机器人配置
# ========================================
# OneBot WebSocket地址
QQ_ONEBOT_WS_URL=ws://localhost:3001

# OneBot访问令牌（可选）
QQ_ONEBOT_TOKEN=

# 机器人QQ号
QQ_BOT_QQ=0

# 超级管理员QQ号（可多个，逗号分隔）
QQ_SUPERADMIN_QQ=0

# 群聊白名单（可选，逗号分隔）
QQ_GROUP_WHITELIST=

# 群聊黑名单（可选，逗号分隔）
QQ_GROUP_BLACKLIST=

# 用户白名单（可选，逗号分隔）
QQ_USER_WHITELIST=

# 用户黑名单（可选，逗号分隔）
QQ_USER_BLACKLIST=

# ========================================
# QQ新功能配置
# ========================================
# 连接设置
# 重连间隔（秒）
QQ_RECONNECT_INTERVAL=5.0

# 心跳间隔（秒）
QQ_PING_INTERVAL=20

# 心跳超时（秒）
QQ_PING_TIMEOUT=30

# 最大消息大小（字节）
QQ_MAX_MESSAGE_SIZE=104857600

# 图片最大大小（字节，10MB）
QQ_IMAGE_MAX_SIZE=10485760

# 允许的图片格式（逗号分隔）
QQ_IMAGE_ALLOWED_FORMATS=.jpg,.jpeg,.png,.gif,.bmp,.webp

# 文件最大大小（字节，50MB）
QQ_FILE_MAX_SIZE=52428800

# OCR功能是否启用
QQ_OCR_ENABLED=true

# OCR引擎：auto, paddleocr, tesseract
QQ_OCR_ENGINE=auto

# 主动聊天功能是否启用
QQ_ACTIVE_CHAT_ENABLED=true

# 每天最多主动消息数
QQ_MAX_DAILY_MESSAGES=10

# 消息最小间隔（秒）
QQ_MIN_INTERVAL=300

# 任务调度功能是否启用
QQ_TASK_SCHEDULER_ENABLED=true

# ========================================
# Redis配置（可选，用于涨潮记忆）
# ========================================
# Redis主机地址
REDIS_HOST=localhost

# Redis端口
REDIS_PORT=6379

# Redis数据库索引
REDIS_DB=0

# Redis密码（可选）
# REDIS_PASSWORD=your_redis_password

# Redis连接池大小
REDIS_MAX_CONNECTIONS=10

# ========================================
# Milvus配置（可选，用于向量长期记忆）
# ========================================
# Milvus主机地址
MILVUS_HOST=localhost

# Milvus端口
MILVUS_PORT=19530

# 集合名称
MILVUS_COLLECTION=miya_memory

# 向量维度（根据embedding模型）
MILVUS_DIMENSION=1536

# 索引类型（IVF_FLAT/HNSW/IVF_PQ）
MILVUS_INDEX_TYPE=IVF_FLAT

# 索引参数（根据索引类型）
MILVUS_INDEX_PARAMS={"nlist":128}

# 使用 Milvus Lite（本地文件模式，无需 Docker）
# true: 使用 Milvus Lite（推荐）
# false: 尝试连接远程 Milvus 服务器
MILVUS_USE_LITE=false

# ========================================
# Neo4j配置（可选，用于知识图谱）
# ========================================
# Neo4j连接URI
NEO4J_URI=bolt://localhost:7687

# Neo4j用户名
NEO4J_USER=neo4j

# Neo4j密码（替换为你的实际密码）
NEO4J_PASSWORD=your_neo4j_password

# Neo4j数据库（可选）
NEO4J_DATABASE=neo4j

# ========================================
# 人格配置（0.0-1.0）
# ========================================
# 温暖度：影响回应的亲和力
PERSONALITY_WARMTH=0.8

# 逻辑性：影响推理的严谨度
PERSONALITY_LOGIC=0.7

# 创造力：影响回答的多样性
PERSONALITY_CREATIVITY=0.6

# 共情力：影响情感理解
PERSONALITY_EMPATHY=0.75

# 韧性：影响抗压能力
PERSONALITY_RESILIENCE=0.7

# ========================================
# 情绪配置
# ========================================
# 情绪衰减率（0.0-1.0）
EMOTION_DECAY_RATE=0.1

# 情绪染色阈值（0.0-1.0）
EMOTION_COLORING_THRESHOLD=0.7

# 情绪传播系数（0.0-1.0）
EMOTION_PROPAGATION_COEFF=0.3

# ========================================
# 信任配置
# ========================================
# 信任衰减率（0.0-1.0）
TRUST_DECAY_RATE=0.05

# 初始信任分数（0.0-1.0）
TRUST_INITIAL_SCORE=0.5

# 高信任阈值（0.0-1.0）
TRUST_HIGH_THRESHOLD=0.7

# 低信任阈值（0.0-1.0）
TRUST_LOW_THRESHOLD=0.3

# ========================================
# 记忆配置
# ========================================
# 潮汐记忆TTL（秒）
MEMORY_TIDE_TTL=3600

# 梦境压缩阈值（条数）
MEMORY_DREAM_THRESHOLD=100

# 短期记忆容量
MEMORY_SHORT_TERM_CAPACITY=20

# 长期记忆检索数量
MEMORY_LONG_TERM_RETRIEVAL=10

# ========================================
# 感知配置
# ========================================
# 感知激活率（0.0-1.0）
PERCEPTION_ACTIVATION_RATE=0.3

# 感知强度阈值（0.0-1.0）
PERCEPTION_INTENSITY_THRESHOLD=0.5

# ========================================
# 检测配置
# ========================================
# 时间环绕检测阈值（秒）
DETECTION_TIME_THRESHOLD=3600

# 空间环绕检测阈值（0.0-1.0）
DETECTION_SPACE_THRESHOLD=1.0

# 节点交叉检测阈值（0.0-1.0）
DETECTION_NODE_THRESHOLD=0.5

# ========================================
# 演化配置
# ========================================
# 沙盒启用
SANDBOX_ENABLED=true

# A/B测试启用
AB_TEST_ENABLED=true

# 用户共演启用
USER_CO_PLAY_ENABLED=true

# ========================================
# Runtime API配置
# ========================================
# API启用
API_ENABLED=true

# API监听地址
API_HOST=0.0.0.0

# API监听端口
API_PORT=8000

# API认证密钥（可选）
# API_AUTH_KEY=your_api_key

# OpenAPI文档启用
API_OPENAPI_ENABLED=true

# ========================================
# Web API配置
# ========================================
# Web API启用
WEB_API_ENABLED=true

# Web API监听地址
WEB_API_HOST=0.0.0.0

# Web API监听端口
WEB_API_PORT=8000

# 公网访问域名（可选，用于 CORS 配置）
WEB_API_DOMAIN=

# 允许的跨域来源
WEB_API_CORS_ORIGINS=*

# ========================================
# WebUI配置
# ========================================
# WebUI启用
WEBUI_ENABLED=true

# WebUI端口
WEBUI_PORT=8080

# WebUI密码（可选）
# WEBUI_PASSWORD=your_webui_password

# ========================================
# MCP配置
# ========================================
# MCP服务器启用
MCP_SERVER_ENABLED=false

# MCP服务器主机
MCP_SERVER_HOST=localhost

# MCP服务器端口
MCP_SERVER_PORT=9000

# ========================================
# IoT配置（可选）
# ========================================
# MQTT代理地址
MQTT_BROKER=localhost

# MQTT端口
MQTT_PORT=1883

# MQTT用户名（可选）
# MQTT_USERNAME=your_mqtt_username

# MQTT密码（可选）
# MQTT_PASSWORD=your_mqtt_password

# ========================================
# 队列配置
# ========================================
# AI请求间隔（秒）
AI_REQUEST_INTERVAL=1.0

# AI请求最大重试次数
AI_REQUEST_MAX_RETRIES=2

# 模型队列间隔（JSON格式）
QUEUE_INTERVALS={"chat_model":1.0,"vision_model":2.0,"agent_model":1.5}

# ========================================
# 语义动力学配置
# ========================================
# 语义衰减率
SEMANTIC_DECAY_RATE=0.05

# 语义组数量
SEMANTIC_GROUP_COUNT=10

# 元思考启用
META_THINKING_ENABLED=true

# 时域解析启用
TIME_EXPRESSION_PARSE_ENABLED=true

# ========================================
# AI客户端配置
# ========================================
# AI提供商（siliconflow/deepseek/zhipu）
# 推荐优先使用硅基流动，成本最低且免费额度充足
AI_PROVIDER=siliconflow

# ========================================
# 硅基流动配置（优先使用）
# ========================================
# 硅基流动 API Key（新用户可免费获得2000万Tokens）
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 硅基流动模型配置
# Qwen 2.5 7B - 快速通用模型（免费）
SILICONFLOW_QWEN_7B_MODEL=Qwen/Qwen2.5-7B-Instruct
# Qwen 2.5 72B - 高性能模型
SILICONFLOW_QWEN_72B_MODEL=Qwen/Qwen2.5-72B-Instruct
# DeepSeek V3 - 硅基流动版本
SILICONFLOW_DEEPSEEK_V3_MODEL=deepseek-ai/DeepSeek-V3
# GLM-4 9B - 清华智谱
SILICONFLOW_GLM_4_MODEL=THUDM/glm-4-9b-chat
# InternLM 2.5 7B - 书生浦语
SILICONFLOW_INTERNLM_MODEL=internlm/internlm2_5-7b-chat

# ========================================
# DeepSeek 官方配置（备选）
# ========================================
# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# DeepSeek V3（通用模型）
DEEPSEEK_V3_MODEL=deepseek-chat
# DeepSeek R1（推理模型）
DEEPSEEK_R1_MODEL=deepseek-reasoner

# ========================================
# 智谱AI配置（新增）
# ========================================
# 智谱AI API Key
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
# GLM-4 Plus - 智谱最新模型
ZHIPU_GLM_4_PLUS_MODEL=glm-4-plus
# GLM-4 - 标准版本
ZHIPU_GLM_4_MODEL=glm-4
# GLM-4V - 多模态版本
ZHIPU_GLM_4V_MODEL=glm-4v
# GLM-4.6V-Flash - 最新免费多模态模型
ZHIPU_GLM_46V_FLASH_MODEL=glm-4.6v-flash

# ========================================
# 通用AI参数
# ========================================
# 最大token数
AI_MAX_TOKENS=2000
# 温度（0.0-2.0，越高越随机）
AI_TEMPERATURE=0.7
# 请求最大重试次数
AI_REQUEST_MAX_RETRIES=2
# 请求超时时间（秒）
AI_REQUEST_TIMEOUT=30

# ========================================
# PaddleOCR配置
# ========================================
# 禁用模型源检查，避免网络连接问题
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
# OCR模型下载路径（可选）
PADDLE_OCR_MODEL_DIR=./models/paddle_ocr

# ========================================
# 提示词配置
# ========================================
# 系统提示词（弥娅的基础人格设定）
# 注意：多行提示词无法在.env中正确解析，请使用 prompts/default.txt
SYSTEM_PROMPT=

# 用户提示词模板（可以包含占位符）
USER_PROMPT_TEMPLATE=用户输入：{user_input}

# 启用记忆上下文（将历史对话添加到提示词）
ENABLE_MEMORY_CONTEXT=true

# 记忆上下文最大条数
MEMORY_CONTEXT_MAX_COUNT=5

# 启用人格上下文（将人格向量添加到提示词）
ENABLE_PERSONALITY_CONTEXT=true

# ========================================
# 性能配置
# ========================================
# 最大并发任务数
MAX_CONCURRENT_TASKS=10

# 任务超时时间（秒）
TASK_TIMEOUT=60

# 内存使用限制（MB）
MEMORY_LIMIT=2048

# ========================================
# 安全配置
# ========================================
# 注入检测启用
INJECTION_DETECTION_ENABLED=true

# 敏感词过滤启用
SENSITIVE_WORD_FILTER_ENABLED=true

# 限流启用
RATE_LIMIT_ENABLED=true

# 限流次数（每分钟）
RATE_LIMIT_PER_MINUTE=30

# ========================================
# 日志配置
# ========================================
# 终端日志启用
LOG_TTY_ENABLED=true

# 日志格式（text/json）
LOG_FORMAT=text

# 日志日期格式
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# ========================================
# LifeBook 记忆管理配置
# ========================================
# LifeBook 启用
LIFEBOOK_ENABLED=true

# LifeBook 数据目录
LIFEBOOK_BASE_DIR=data/lifebook

# 自动总结启用（需要 AI 客户端）
LIFEBOOK_AUTO_SUMMARY=false

# 默认回溯月数
LIFEBOOK_DEFAULT_MONTHS_BACK=1

# ========================================
# 对话历史上下文配置
# ========================================
# 是否启用对话历史上下文（传递最近N条对话给AI）
ENABLE_CONVERSATION_CONTEXT=false

# 对话历史上下文最大条数（控制token消耗）
CONVERSATION_CONTEXT_MAX_COUNT=5

# 对话历史上下文最大token数（防止超出模型限制）
CONVERSATION_CONTEXT_MAX_TOKENS=1000

# ========================================
# GitHub 博客配置（可选，用于博客版本控制）
# ========================================
# GitHub 仓库所有者
# GITHUB_REPO_OWNER=your_github_username

# GitHub 仓库名称
# GITHUB_REPO_NAME=your_repo_name

# GitHub Personal Access Token
# GITHUB_TOKEN=your_github_token

# GitHub 分支名称
# GITHUB_BRANCH=main
