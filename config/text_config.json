    "active_chat": {
        "enabled": true,
        
        "triggers": {
            "keyword": {
                "enabled": true,
                "description": "关键词触发 - 已禁用"
            },
            "time": {
                "enabled": false,
                "description": "时间触发 - 定时问候(早安/午安/晚安)"
            },
            "context": {
                "enabled": false,
                "description": "上下文触发 - 已禁用"
            },
            "ai": {
                "enabled": false,
                "description": "AI自主判断 - 已禁用，避免刷屏"
            }
        },
        
        "keyword_trigger": {
            "enabled": true,
            "description": "已禁用 - 关键词触发过于频繁，改用AI自主判断",
            "keywords": ["晚安", "早安", "午安", "睡觉", "下班", "吃饭", "学习", "辛苦了", "好累"],
            "cooldown": 1800,
            "response_type": "ai_generate",
            "min_interval_seconds": 1800
        },
        
        "time_trigger": {
            "enabled": true,
            "morning": {"enabled": true, "start": 6, "end": 9},
            "afternoon": {"enabled": true, "start": 11, "end": 14},
            "evening": {"enabled": true, "start": 17, "end": 21},
            "night": {"enabled": true, "start": 22, "end": 24},
            "min_interval_hours": 6
        },
        
        "context_trigger": {
            "enabled": false,
            "description": "已禁用 - 上下文跟进过于频繁",
            "followup_delay_seconds": 300,
            "reminder_delay_seconds": 120
        },
        
        "ai_trigger": {
            "enabled": true,
            "check_interval": 300,
            "max_messages_per_hour": 2,
            "min_trigger_interval_seconds": 600,
            "min_user_inactive_minutes": 30,
            "context_awareness": {
                "include_group_info": true,
                "include_member_count": true,
                "include_recent_topics": true
            },
            "system_prompt": "你是弥娅，一个温暖的AI助手。你会根据当前聊天环境和用户状态，判断是否需要主动发起对话。请基于以下情况决定是否回复：\n\n【当前环境】\n- 聊天类型: {chat_type}\n- 群名称: {group_name}\n- 成员数: {member_count}\n\n【用户状态】\n- 最后活跃: {last_active}\n- 最近话题: {recent_topics}\n\n如果需要回复，请用简洁温暖的话语（不超过20字），不需要回复时回复\"SKIP\"。"
        },
        
        "context_awareness": {
            "enabled": true,
            "track_group_info": true,
            "track_private_chat": true,
            "group_context_fields": ["group_name", "member_count", "recent_message_count"],
            "private_context_fields": ["last_active", "message_count_today"]
        },
        
        "global_settings": {
            "trigger_cooldown": 300,
            "check_interval": 60,
            "context_expiry_hours": 24,
            "max_retry": 3,
            "retry_interval": 30,
            "max_daily_messages": 10,
            "enable_group_awareness": true,
            "enable_private_awareness": true
        }
    }
