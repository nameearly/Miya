{
  "description": "系统常量配置 - 超时/重试/限制等参数",

  "database": {
    "redis": {
      "default_port": 6379,
      "default_db": 0,
      "connection_timeout": 30,
      "socket_timeout": 30
    },
    "milvus": {
      "default_port": 19530,
      "default_index_type": "IVF_FLAT"
    },
    "neo4j": {
      "default_port": 7687,
      "default_http_port": 7474
    },
    "chromadb": {
      "default_port": 8000
    }
  },

  "terminal": {
    "default_timeout_ms": 120000,
    "max_timeout_ms": 600000,
    "progress_threshold_ms": 2000,
    "default_max_size": 10485760,
    "default_limit": 2000,
    "default_max_results": 1000,
    "default_head_limit": 250,
    "max_file_read_size": 10485760,
    "file_read_chunk_size": 8192,
    "max_history_entries": 1000,
    "enable_history": true,
    "enable_progress_tracking": true,
    "enable_command_suggestions": true,
    "security_level": "safe",
    "blocked_commands": [
      "rm -rf /",
      "rm -rf /*",
      "mkfs",
      "dd if=/dev/zero",
      ":(){ :|:& };:",
      "fork()",
      "> /dev/sd",
      "chmod -R 777 /"
    ],
    "dangerous_patterns": [
      "rm -rf",
      "rm -r",
      "del /",
      "format",
      "chmod 777"
    ],
    "caution_patterns": [
      "rm ",
      "del ",
      "mv ",
      "cp -r"
    ],
    "whitelist": {
      "read": [
        "ls", "dir", "pwd", "cd", "cat", "more", "less", "head", "tail",
        "grep", "find", "where", "which", "git log", "git show", "git diff",
        "git status", "git branch", "git remote", "git tag", "ps", "top",
        "df", "du", "free", "uptime", "uname", "hostname", "date", "whoami",
        "ping", "traceroute", "nslookup", "netstat", "ifconfig",
        "Get-ChildItem", "Get-Location", "Set-Location", "Get-Content",
        "Select-String", "Get-Process", "Test-Connection",
        "Get-NetIPConfiguration", "Get-NetTCPConnection"
      ],
      "write": [
        "touch", "mkdir", "cp", "mv", "copy", "move", "echo", "printf",
        "git add", "git commit", "git push", "git pull", "git checkout",
        "git merge", "git rebase", "New-Item", "Copy-Item", "Move-Item"
      ],
      "dangerous": [
        "rm", "rmdir", "del", "erase", "Remove-Item", "kill", "pkill",
        "killall", "Stop-Process", "sudo", "su", "chmod", "chown", "chgrp"
      ]
    }
  },

  "network": {
    "connection_timeout": 30,
    "read_timeout": 60,
    "max_retries": 3,
    "retry_delay": 1,
    "pool_size": 10,
    "max_connections": 100
  },

  "api": {
    "max_tokens_default": 4096,
    "max_tokens_limit": 10000,
    "temperature_default": 0.7,
    "top_p_default": 0.9,
    "frequency_penalty_default": 0.1,
    "presence_penalty_default": 0.1,
    "max_concurrent_requests": 10,
    "request_timeout": 120
  },

  "tool": {
    "max_retries": 3,
    "retry_delay": 2,
    "execution_timeout": 300,
    "max_memory_mb": 512,
    "max_concurrent_tasks": 10
  },

  "message": {
    "max_length": 10000,
    "max_history_length": 50,
    "max_messages_per_session": 200,
    "qq_max_message_length": 200,
    "qq_max_api_count": 500,
    "websocket_max_message_size": 104857600
  },

  "memory": {
    "context_max_count": 10,
    "context_max_tokens": 2000,
    "short_term_max": 20,
    "long_term_max": 1000
  },

  "cognitive": {
    "personality_max_adjustment": 0.05,
    "emotion_decay_rate": 0.1,
    "mood_trend_window": 7
  },

  "qq": {
    "max_message_size": 104857600,
    "image_max_size": 10485760,
    "file_max_size": 52428800,
    "max_daily_messages": 10,
    "min_interval": 300,
    "max_retry": 3,
    "timeout": 480
  },

  "mlink": {
    "default_timeout": 30,
    "heartbeat_interval": 60,
    "reconnect_delay": 5,
    "max_reconnect_attempts": 3
  },

  "game": {
    "quintuple_retry_increment": 20,
    "trpg_max_players": 8,
    "trpg_default_timeout": 300
  }
}