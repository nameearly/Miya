{
    "agent_routing": {
        "description": "Agent 路由配置 - 定义关键词到 Agent 的映射关系",
        "enabled": true,
        
        "routing_rules": {
            "info_agent": {
                "keywords": [
                    "天气", "热搜", "新闻", "查询", "搜索", 
                    "天气怎么样", "微博热搜", "抖音热搜", "百度热搜", 
                    "论文", "qq等级", "ping", "whois"
                ],
                "description": "信息查询助手 - 天气、新闻、搜索等"
            },
            "web_agent": {
                "keywords": [
                    "搜索", "网络", "网页", "爬取", "链接", "网址", 
                    "查一下", "帮我找"
                ],
                "description": "网络搜索助手"
            },
            "entertainment_agent": {
                "keywords": [
                    "画图", "画画", "占卜", "游戏", "抽签", "运势",
                    "星座", "双鱼座", "白羊座", "金牛座", "双子座",
                    "巨蟹座", "狮子座", "处女座", "天秤座", "天蝎座",
                    "射手座", "摩羯座", "水瓶座", "拍一拍"
                ],
                "description": "娱乐助手 - 画画、占卜、游戏、星座运势"
            },
            "file_analysis_agent": {
                "keywords": [
                    "分析", "文件", "解读", "pdf", "文档",
                    "读文件", "看图", "图片分析", "识别图片",
                    "群文件", "下载文件", "看看群文件",
                    "找不到", "帮我找", "文件在哪", "搜索文件"
                ],
                "description": "文件分析助手 - 文件读取、图片分析、群文件、本地搜索"
            },
            "code_delivery_agent": {
                "keywords": [
                    "代码", "编程", "写代码", "开发", "程序",
                    "运行代码", "执行Python", "计算", "数据分析"
                ],
                "description": "代码交付助手 - 编程、执行代码"
            }
        },
        
        "fallback": {
            "description": "未匹配时的回退策略",
            "use_direct_tools": true
        }
    }
}