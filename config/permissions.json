  "special_rules": {
    "admin_whitelist": [
      "terminal_default",
      "1523878699",
      "qq_1523878699",
      "terminal_1523878699"
    ],
    "super_admin_whitelist": [
      "terminal_default",
      "1523878699",
      "qq_1523878699",
      "terminal_1523878699"
    ]
  },

  "disabled_permissions": [],

  "platform_restrictions": {
    "terminal": {
      "allowed_groups": [],
      "forbidden_groups": []
    },
    "web": {
      "allowed_groups": [],
      "forbidden_groups": ["Terminal"]
    },
    "desktop": {
      "allowed_groups": [],
      "forbidden_groups": []
    },
    "qq": {
      "allowed_groups": ["Default", "QQ", "Web", "Admin", "Developer"],
      "forbidden_groups": []
