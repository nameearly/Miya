[MASTER]
# 指定配置文件
rcfile=

# Python代码文件
python-path=

# 加载插件的路径
init-hook='import sys; sys.path.append(".")'

# 使用哪个解析器
extension-pkg-allow-list=

# 分析多个文件时优化
persistent=yes

# 允许的最大行长度
max-line-length=88

# 忽略的文件/目录
ignore-patterns=
    ^.git/
    ^.venv/
    ^venv/
    ^build/
    ^dist/
    ^docs/
    ^tests/

# 忽略的模块
ignore=CVS

# 要分析的Python模块
jobs=1

# 加载全局配置
load-plugins=

# 总是评估的最小子句数
suggestion-mode=yes

# 错误输出格式
output-format=colorized

# 消息格式
msg-template={path}:{line}:{column}: {msg_id} {obj}: {msg}

# 报告格式
reports=yes

# 评估语句复杂度
evaluation=max(0, 0 if line else 0)

# 缓存目录
cache-directory=.pylint.d

# 允许的最多公共方法
max-public-methods=20

# 允许的最多参数
max-args=10

# 允许的最多属性
max-attributes=20

# 允许的最多局部变量
max-locals=25

# 允许的最多返回语句
max-returns=6

# 允许的最多分支
max-branches=15

# 允许的最多语句
max-statements=50

# 允许的最多父类
max-parents=7

# 允许的最多方法
max-methods=40

# 允许的最多行数
max-module-lines=2000

# 允许的最多行数（方法）
max-method-lines=100

# 代码重复阈值
duplicate-code-min-lines=4

# 评分公式
evaluation=10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10)

[MESSAGES CONTROL]
# 启用消息
enable=
    all

# 禁用消息
disable=
    # 以下为常见需要禁用的检查
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-many-lines,
    too-many-arguments,
    too-many-locals,
    too-many-statements,
    too-many-branches,
    too-many-instance-attributes,
    too-few-public-methods,
    too-many-public-methods,
    duplicate-code,
    fixme,
    # 以下为与black冲突的格式检查
    bad-continuation,
    trailing-whitespace,
    bad-whitespace,
    mixed-line-endings,
    # 以下为过于严格的检查
    consider-using-f-string,
    # 以下为特定情况需要禁用的
    unused-argument,
    broad-except,
    redefined-outer-name,
    protected-access,
    consider-using-with,
    unspecified-encoding,
    # 以下为与类型提示相关的
    unsubscriptable-object,
    unsupported-assignment-operation,
    unsupported-delete-operation,
    # 以下为异步相关
    consider-using-async-with,
    consider-using-async-for,

[REPORTS]
# 输出格式
output-format=text

# 报告
reports=yes

# 评估
evaluation=10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10)

# 消息分类
score=yes

[REFACTOR]
# 重构建议
max-nested-blocks=5

[SIMILARITIES]
# 相似性检查
min-similarity-lines=4
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=no

[BASIC]
# 命名约定
# 模块名: lowercase-with-underscores
module-rgx=^[_a-z][_a-z0-9]*$
# 常量名: UPPER_CASE
const-rgx=^[A-Z_][A-Z0-9_]*$
# 类名: CapWords
class-rgx=^[A-Z_][a-zA-Z0-9]*$
# 函数名: lowercase_with_underscores
function-rgx=^[_a-z][_a-z0-9]*$
# 方法名: lowercase_with_underscores
method-rgx=^[_a-z][_a-z0-9]*$
# 属性名: lowercase_with_underscores
attr-rgx=^[_a-z][_a-z0-9]*$
# 参数名: lowercase_with_underscores
argument-rgx=^[_a-z][_a-z0-9]*$
# 变量名: lowercase_with_underscores
variable-rgx=^[_a-z][_a-z0-9]*$
# 类属性名: (?!^[A-Z_][A-Z0-9_]*$)
class-attribute-rgx=^[_a-z][_a-z0-9]*$
# 内联变量名: ^_?[a-z][a-z0-9]*$
inlinevar-rgx=^[_a-z][_a-z0-9]*$
# 第一个参数名
first-argument-rgx=^[_a-z][_a-z0-9]*$
# 好的变量名
good-names=
    i,
    j,
    k,
    ex,
    Run,
    _,
    e,
    err,
    # 以下为测试常用名
    test,
    expected,
    actual,
    result,
    mock,
    fixture,
    # 以下为异步常用名
    task,
    future,
    loop,
    # 以下为类型提示常用名
    T,
    P,
    R,
    KT,
    VT,

# 不好的变量名
bad-names=
    foo,
    bar,
    baz,
    toto,
    tutu,
    tata,

# 好的函数名
good-functions=
    setUp,
    tearDown,
    setUpClass,
    tearDownClass,
    # 异步测试
    asyncSetUp,
    asyncTearDown,

# 导入模块
additional-builtins=

# 要忽略的类
ignored-classes=optparse.Values,threading._local,_thread._local

# 字符串格式
string-formatting=old,new,f-string

# 字符串常量
check-str-concat-over-line-jumps=no

[TYPECHECK]
# 类型检查
# 忽略的模块
ignored-modules=
# 忽略的类
ignored-classes=
# 忽略的类型名称
ignored-type-names=
# 生成器
generated-members=
# 上下文管理器
contextmanager-decorators=contextlib.contextmanager
# 未使用的变量
ignore-on-opaque-inference=yes
# 混合
mixin-class-rgx=.*[Mm]ixin
# 签名杂项
signature-mutators=

# 忽略的检查
disable=
    no-member,
    # 以下为常见需要忽略的类型检查
    assignment-from-no-return,
    assignment-from-none,
    not-callable,
    unsubscriptable-object,
    unsupported-assignment-operation,
    unsupported-delete-operation,
    # 以下为与动态类型相关的
    untyped-def,
    missing-return-type,

# 启用检查
enable-only=

# 忽略导入
ignore-imports=yes

# 忽略混合
ignore-mixin-members=yes

# 忽略名称
ignore-names=
# 忽略的属性
ignore-on-opaque-inference=yes

# 覆盖
overgeneral-exceptions=Exception

[VARIABLES]
# 变量
# 额外的内置函数
additional-builtins=
# 调用上下文
callbacks=callback_,_cb
# 初始化提示
init-import=no
# 默认值提示
dummy-variables-rgx=^(_+[a-zA-Z0-9]*)?$
# 额外的常量
additional-const-names=
# 额外的模块
additional-modules=

[FORMAT]
# 格式
# 最大行长度
max-line-length=88
# 忽略的注释
ignore-long-lines=^\s*(# )?<?https?://\S+>?$
# 单行if语句
single-line-if-stmt=no
# 无空格行
no-space-check=
# 导入组
import-group=yes
# 悬挂缩进
hanging-indent=yes
# 期望的缩进
indent-after-paren=4
# 缩进字符串
indent-string='    '
# 最大空行数
max-module-lines=2000

[LOGGING]
# 日志
# 日志格式
logging-format-style=new
# 日志级别
logging-level=WARNING

[MISCELLANEOUS]
# 杂项
# 笔记
notes=FIXME,XXX,TODO
# 字符串常量
string-constant=yes

[DESIGN]
# 设计
# 最大参数
max-args=10
# 最大属性
max-attributes=20
# 最大局部变量
max-locals=25
# 最大返回语句
max-returns=6
# 最大分支
max-branches=15
# 最大语句
max-statements=50
# 最大父类
max-parents=7
# 最大方法
max-methods=40
# 最大行数（模块）
max-module-lines=2000
# 最大行数（方法）
max-method-lines=100
# 最小公共方法
min-public-methods=0

[IMPORTS]
# 导入
# 依赖图
deprecated-modules=
# 导入图形
import-graph=
# 扩展导入图形
ext-import-graph=
# 内部导入图形
int-import-graph=
# 已知的标准库
known-standard-library=
# 已知的第三方
known-third-party=
    fastapi,
    pydantic,
    aiohttp,
    uvicorn,
    openai,
    anthropic,
    torch,
    transformers,
    chromadb,
    neo4j,
    redis,
    pytest,
# 已知的第一个方
known-first-party=
    core,
    hub,
    memory,
    run,
    webnet,
    config,
# 分析多个文件
analyse-fallback-blocks=no

[CLASSES]
# 类
# 定义类名的有效名称
valid-class-name=CapWords
# 有效的方法名
valid-method-name=lowercase_with_underscores
# 有效的属性名
valid-attr-name=lowercase_with_underscores
# 类文档字符串样式
docstring-style=google
# 方法文档字符串样式
method-docstring-style=google
# 属性文档字符串样式
attr-docstring-style=google

[EXCEPTIONS]
# 异常
# 过度泛化的异常
overgeneral-exceptions=Exception
# 忽略的检查
disable=
    broad-except,
    # 以下为特定情况需要忽略的
    bare-except,
    try-except-raise,
    misplaced-bare-raise,
    # 以下为与异步相关的
    broad-exception-caught,