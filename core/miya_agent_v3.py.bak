#!/usr/bin/env python3
"""
弥亚智能代理 V3 - AI驱动的推理引擎
使用AI大模型真正理解用户意图并推理出正确的命令
"""

import asyncio
import platform
from typing import Dict, List, Optional, Any


class MiyaAgentV3:
    """
    弥亚智能代理 V3 - AI推理版本

    核心区别:
    - V1/V2: 规则匹配 (if '打开' then 'start xxx')
    - V3: AI推理 (理解意图 → 推理命令 → 执行 → 验证)
    """

    def __init__(self):
        self.os_type = platform.system().lower()  # windows, linux, darwin
        self.is_windows = self.os_type == "windows"
        self.is_linux = self.os_type == "linux"
        self.is_macos = self.os_type == "darwin"

    async def run(self, user_request: str, model_client=None) -> str:
        """
        使用AI推理处理请求
        """
        if not model_client:
            return "❌ 需要AI模型才能使用V3代理"

        # 步骤1: AI理解用户意图
        intent_analysis = await self._ai_analyze(user_request, model_client)

        # 步骤2: AI推理出正确的命令
        command_plan = await self._ai_plan_command(
            intent_analysis, user_request, model_client
        )

        # 步骤3: 执行命令
        execution_result = await self._execute_command(command_plan)

        # 步骤4: AI验证结果
        verification = await self._ai_verify(
            user_request, execution_result, model_client
        )

        # 步骤5: 如果失败,AI尝试修正
        if not verification["success"] and verification.get("alternative"):
            execution_result = await self._execute_command(verification["alternative"])
            verification = await self._ai_verify(
                user_request, execution_result, model_client
            )

        # 生成响应
        return self._format_response(
            user_request, intent_analysis, command_plan, execution_result
        )

    async def _ai_analyze(self, request: str, model_client) -> Dict:
        """让AI分析用户意图"""
        os_info = f"当前系统: {self.os_type}"
        
        prompt = f"""你是一个跨平台系统专家。请分析用户的请求,理解他们的真实意图。

{os_info}

用户请求: "{request}"

请用JSON格式回答:
{{
    "intent": "用户真正想要做什么,用一句话描述",
    "target": "目标应用或文件",
    "platform": "windows/linux/macos/mixed/unknown",
    "confidence": 0.0-1.0
}}

分析:

        try:
            from core.ai_client import AIMessage

            messages = [AIMessage(role="user", content=prompt)]
            result = await model_client.chat(messages)
            content = result.content if hasattr(result, "content") else str(result)

            # 解析JSON
            import json
            import re

            match = re.search(r"\{.*\}", content, re.DOTALL)
            if match:
                return json.loads(match.group(0))
        except:
            pass

        return {
            "intent": f"打开{request}",
            "target": request,
            "platform": "unknown",
            "confidence": 0.5,
        }

    async def _ai_plan_command(self, intent: Dict, request: str, model_client) -> Dict:
        """让AI推理出正确的命令"""
        os_info = f"当前系统: {self.os_type}"

        prompt = f"""你是一个跨平台系统专家。用户想执行操作,请推理出正确的命令。

{os_info}

用户请求: "{request}"
分析意图: {intent.get("intent", "unknown")}
目标: {intent.get("target", "unknown")}

请用JSON格式回答:
{{
    "command": "正确的命令(只写命令,不要解释)",
    "args": "命令参数",
    "method": "shell/exec/powershell",
    "reasoning": "为什么用这个命令,一句话"
}}

根据系统类型选择正确的命令:
- Windows: start notepad, taskmgr, calc 等
- Linux: xdg-open, gnome-terminal, etc.
- macOS: open, say, etc.

示例:
请求: "打开任务管理器"
系统: windows
推理: Windows的任务管理器命令是 taskmgr.exe

请求: "打开记事本"  
系统: windows
推理: Windows的记事本命令是 notepad.exe

现在推理:
请求: "{request}"
系统: {self.os_type}
"""

        try:
            from core.ai_client import AIMessage

            messages = [AIMessage(role="user", content=prompt)]
            result = await model_client.chat(messages)
            content = result.content if hasattr(result, "content") else str(result)

            import json
            import re

            match = re.search(r"\{.*\}", content, re.DOTALL)
            if match:
                plan = json.loads(match.group(0))
                # 提取纯命令
                cmd = plan.get("command", "").strip()
                return {
                    "command": cmd,
                    "args": plan.get("args", ""),
                    "method": plan.get("method", "shell"),
                    "reasoning": plan.get("reasoning", ""),
                }
        except Exception as e:
            pass

        # 回退: 智能规则
        return self._fallback_command(request)

    def _fallback_command(self, request: str) -> Dict:
        """回退到规则 - 支持跨平台"""
        r = request.lower()

        # 根据操作系统选择命令
        if self.is_windows:
            apps = {
                "任务管理器": "taskmgr",
                "task manager": "taskmgr",
                "记事本": "notepad",
                "notepad": "notepad",
                "计算器": "calc",
                "calculator": "calc",
                "浏览器": "start chrome",
                "chrome": "start chrome",
                "火狐": "start firefox",
                "firefox": "start firefox",
                "微信": "start wechat",
                "wechat": "start wechat",
                "qq": "start qq",
                "资源管理器": "explorer",
                "explorer": "explorer",
                "控制面板": "control",
                "powershell": "start powershell",
                "cmd": "start cmd",
                "画图": "mspaint",
                "写字板": "write",
                "远程桌面": "mstsc",
            }
        elif self.is_linux:
            apps = {
                "文件管理器": "xdg-open",
                "文件": "xdg-open",
                "浏览器": "xdg-open https://www.google.com",
                "chrome": "xdg-open https://www.google.com",
                "终端": "gnome-terminal || xterm || konsole",
                "计算器": "gnome-calculator || kcalc",
                "记事本": "gedit || nano",
                "文本编辑器": "gedit || nano",
            }
        elif self.is_macos:
            apps = {
                "任务管理器": "open -a Activity\\ Monitor",
                "task manager": "open -a Activity\\ Monitor",
                "记事本": "open -a TextEdit",
                "notepad": "open -a TextEdit",
                "计算器": "open -a Calculator",
                "calculator": "open -a Calculator",
                "浏览器": "open -a Safari",
                "safari": "open -a Safari",
                "chrome": "open -a Google\\ Chrome",
                "终端": "open -a Terminal",
                "finder": "open .",
                "资源管理器": "open .",
            }
        else:
            apps = {}

        for key, cmd in apps.items():
            if key in r:
                return {
                    "command": cmd,
                    "args": "",
                    "method": "shell",
                    "reasoning": f"匹配关键词: {key} ({self.os_type})",
                }

        return {
            "command": request,
            "args": "",
            "method": "shell",
            "reasoning": "直接执行",
        }

    async def _execute_command(self, plan: Dict) -> Dict:
        """执行命令"""
        from core.terminal_ultra import get_terminal_ultra

        terminal = get_terminal_ultra()

        cmd = plan.get("command", "")
        method = plan.get("method", "shell")

        try:
            result = await terminal.terminal_exec(cmd)
            return {
                "success": result.success,
                "output": result.output,
                "error": result.error,
                "command": cmd,
            }
        except Exception as e:
            return {"success": False, "output": "", "error": str(e), "command": cmd}

    async def _ai_verify(self, request: str, result: Dict, model_client) -> Dict:
        """让AI验证执行结果"""
        prompt = f"""你是一个系统诊断专家。请验证命令执行结果。

用户请求: "{request}"
执行命令: {result.get("command", "")}
退出码: {0 if result.get("success") else 1}
输出: {result.get("output", "")[:500]}
错误: {result.get("error", "")[:200]}

请用JSON格式回答:
{{
    "success": true/false,
    "analysis": "命令是否完成了用户的请求,一句话",
    "alternative": "如果失败,尝试什么新命令(如果没有则null)"
}}

验证:"""

        try:
            from core.ai_client import AIMessage

            messages = [AIMessage(role="user", content=prompt)]
            response = await model_client.chat(messages)
            content = (
                response.content if hasattr(response, "content") else str(response)
            )

            import json
            import re

            match = re.search(r"\{.*\}", content, re.DOTALL)
            if match:
                return json.loads(match.group(0))
        except:
            pass

        # 回退验证
        return {
            "success": result.get("success", False),
            "analysis": "无法验证",
            "alternative": None,
        }

    def _format_response(
        self, request: str, intent: Dict, plan: Dict, result: Dict
    ) -> str:
        """格式化响应"""
        output = []

        output.append("=" * 60)
        output.append("【弥亚智能代理 V3 - AI推理引擎】")
        output.append("=" * 60)

        # 意图分析
        output.append("\n📋 【意图理解】")
        output.append(f"  用户说: {request}")
        output.append(f"  理解意图: {intent.get('intent', 'unknown')}")
        output.append(f"  目标: {intent.get('target', 'unknown')}")

        # 命令规划
        output.append("\n💭 【AI推理】")
        output.append(f"  推理命令: {plan.get('command', '')}")
        output.append(f"  推理理由: {plan.get('reasoning', '')}")

        # 执行结果
        output.append("\n⚡ 【执行结果】")
        if result.get("success"):
            output.append("  ✓ 命令执行成功")
        else:
            output.append("  ✗ 命令执行失败")

        # 显示输出
        output_text = result.get("output", "") or result.get("error", "")
        if output_text:
            if len(output_text) > 600:
                output.append(f"\n{output_text[:600]}\n... (截断)")
            else:
                output.append(f"\n{output_text}")

        return "\n".join(output)


# 全局实例
_agent_v3_instance = None


def get_miya_agent_v3() -> MiyaAgentV3:
    global _agent_v3_instance
    if _agent_v3_instance is None:
        _agent_v3_instance = MiyaAgentV3()
    return _agent_v3_instance
